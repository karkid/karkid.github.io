{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "site-data/miscellaneous",
    "title": "Site Miscellaneous",
    "description": "window.SITE_DATA_MISCELLANEOUS",
    "type": "object",
    "required": [
        "miscellaneous_intro",
        "miscellaneous"
    ],
    "additionalProperties": false,
    "properties": {
        "miscellaneous_intro": {
            "type": "string",
            "minLength": 1
        },
        "miscellaneous": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "category",
                    "note",
                    "date"
                ],
                "additionalProperties": false,
                "properties": {
                    "id": {
                        "type": [
                            "string",
                            "number"
                        ]
                    },
                    "category": {
                        "type": "string",
                        "enum": [
                            "Reading",
                            "Watching",
                            "Listening",
                            "Gaming",
                            "Exploring",
                            "Reflections"
                        ]
                    },
                    "type": {
                        "type": "string"
                    },
                    "title": {
                        "type": "string"
                    },
                    "note": {
                        "type": "string",
                        "minLength": 1
                    },
                    "imageUrl": {
                        "type": "string"
                    },
                    "tags": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "minLength": 1
                        }
                    },
                    "metadata": {
                        "type": "object",
                        "additionalProperties": {
                            "anyOf": [
                                {
                                    "type": [
                                        "string",
                                        "number",
                                        "boolean"
                                    ]
                                },
                                {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": [
                                            "string",
                                            "number",
                                            "boolean"
                                        ]
                                    }
                                }
                            ]
                        }
                    },
                    "sourceUrl": {
                        "type": "string"
                    },
                    "date": {
                        "type": "string",
                        "anyOf": [
                            {
                                "format": "date"
                            },
                            {
                                "format": "date-time"
                            }
                        ]
                    },
                    "createdAt": {
                        "type": "string",
                        "anyOf": [
                            {
                                "format": "date"
                            },
                            {
                                "format": "date-time"
                            }
                        ]
                    },
                    "updatedAt": {
                        "type": "string",
                        "anyOf": [
                            {
                                "format": "date"
                            },
                            {
                                "format": "date-time"
                            }
                        ]
                    }
                }
            }
        }
    }
}