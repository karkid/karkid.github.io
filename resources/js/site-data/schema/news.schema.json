{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "site-data/news",
    "title": "Site News",
    "description": "window.SITE_DATA_NEWS",
    "type": "object",
    "required": [
        "news_intro",
        "news"
    ],
    "additionalProperties": false,
    "properties": {
        "news_intro": {
            "type": "string",
            "minLength": 1
        },
        "news": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "date",
                    "headline"
                ],
                "additionalProperties": false,
                "properties": {
                    "date": {
                        "type": "string",
                        "format": "date"
                    },
                    "headline": {
                        "type": "string",
                        "minLength": 1
                    },
                    "link": {
                        "type": "string"
                    }
                }
            }
        }
    }
}