{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "site-data/journey",
    "title": "Site Journey",
    "description": "window.SITE_DATA_JOURNEY",
    "type": "object",
    "required": [
        "journey_intro",
        "journey"
    ],
    "additionalProperties": false,
    "properties": {
        "journey_intro": {
            "type": "string",
            "minLength": 1
        },
        "journey": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "year",
                    "icon",
                    "location",
                    "event",
                    "outcome",
                    "reward"
                ],
                "additionalProperties": false,
                "properties": {
                    "year": {
                        "type": "string",
                        "minLength": 1
                    },
                    "icon": {
                        "type": "string",
                        "minLength": 1
                    },
                    "location": {
                        "type": "string",
                        "minLength": 1
                    },
                    "event": {
                        "type": "string",
                        "minLength": 1
                    },
                    "outcome": {
                        "type": "string"
                    },
                    "reward": {
                        "type": "string"
                    }
                }
            }
        }
    }
}